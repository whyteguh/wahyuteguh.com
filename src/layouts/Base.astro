---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Personal website of Wahyu Teguh — figuring out how intelligence, business, and kindness can work together.',
} = Astro.props;

const isHome = Astro.url.pathname === '/';

const socials = [
  { label: 'instagram', href: 'https://www.instagram.com/wahyuteguh/' },
  { label: 'linkedin', href: 'https://www.linkedin.com/in/wahyu-teguh/' },
  { label: 'threads', href: 'https://www.threads.com/@wahyuteguh' },
  { label: 'youtube', href: 'https://www.youtube.com/@whyteguh' },
  { label: 'facebook', href: 'https://www.facebook.com/why.dv' },
  { label: 'x', href: 'https://x.com/why_teguh' },
];
---
<html lang="en" data-mode="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Caveat:wght@400;600;700&family=Dancing+Script:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      try {
        var m = localStorage.getItem('wt-mode');
        if (m) document.documentElement.dataset.mode = m;
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="ink-overlay" id="ink-overlay"></div>

    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">☾ ink</button>

    <div class="page">
      <div class="ruled">
        <div class="rule"></div>
        <div class="flow">
          <slot />

          {
            isHome ? (
              <div class="sec" style="gap:16px">
                <div class="note r1">elsewhere</div>
                <div class="social-row">
                  {socials.map((s) => (
                    <a href={s.href} target="_blank" rel="noopener">{s.label}</a>
                  ))}
                </div>
                <div class="colophon">
                  © {new Date().getFullYear()} wahyuteguh · written on dot paper, occasionally enchanted
                </div>
              </div>
            ) : (
              <div class="sec" style="gap:16px">
                <div class="colophon">
                  © {new Date().getFullYear()} wahyuteguh · <a href="/">home</a>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var root = document.documentElement;
        var overlay = document.getElementById('ink-overlay');
        var toggle = document.getElementById('theme-toggle');
        var photo = document.getElementById('polaroid');
        var spellNote = document.getElementById('spell-note');
        var spreading = false;

        function mode() {
          return root.dataset.mode || 'paper';
        }
        function sync() {
          toggle.textContent = mode() === 'dark' ? '☀ paper' : '☾ ink';
          if (spellNote) spellNote.textContent = mode() === 'magic' ? '↑break the spell' : '↑cast the spell✨';
          if (photo) photo.title = mode() === 'magic' ? 'click to break the spell' : 'click me ✨';
        }
        function setMode(m) {
          root.dataset.mode = m;
          try {
            localStorage.setItem('wt-mode', m);
          } catch (e) {}
          sync();
        }

        toggle.addEventListener('click', function () {
          setMode(mode() === 'dark' ? 'paper' : 'dark');
        });

        if (photo) {
          photo.addEventListener('click', function (e) {
            if (spreading) return;
            spreading = true;
            overlay.style.setProperty('--ix', e.clientX + 'px');
            overlay.style.setProperty('--iy', e.clientY + 'px');
            overlay.classList.add('spread');
            var target = mode() === 'magic' ? 'paper' : 'magic';
            setTimeout(function () {
              setMode(target);
            }, 460);
            setTimeout(function () {
              overlay.classList.remove('spread');
              spreading = false;
            }, 1150);
          });
        }

        sync();
      })();
    </script>
  </body>
</html>

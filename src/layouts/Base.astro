---
import '../styles/global.css';
import { socials } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  /** Hide the red margin rule and center the content column (e.g. /link). */
  centered?: boolean;
}

const {
  title,
  description = 'Personal website of Wahyu Teguh — figuring out how intelligence, business, and kindness can work together.',
  centered = false,
} = Astro.props;

const isHome = Astro.url.pathname === '/';
---
<html lang="en" data-mode="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Caveat:wght@400;600;700&family=Dancing+Script:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      try {
        var m = localStorage.getItem('wt-mode');
        if (m) document.documentElement.dataset.mode = m;
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="freeze-overlay" id="freeze-overlay"></div>
    <canvas class="freeze-canvas" id="freeze-canvas"></canvas>
    <video class="freeze-video" id="freeze-video" src="/freeze.mp4" preload="auto" playsinline crossorigin="anonymous"></video>

    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">☾ ink</button>

    <div class="page">
      <div class="ruled">
        {!centered && <div class="rule"></div>}
        <div class={centered ? 'flow centered' : 'flow'}>
          <slot />

          {
            isHome ? (
              <div class="sec" style="gap:16px">
                <div class="note r1">elsewhere</div>
                <div class="social-row">
                  {socials.map((s) => (
                    <a href={s.href} target="_blank" rel="noopener">{s.label}</a>
                  ))}
                </div>
                <div class="colophon">
                  © {new Date().getFullYear()} wahyuteguh · written on dot paper, occasionally frozen over ❄
                </div>
              </div>
            ) : (
              <div class="sec" style="gap:16px">
                <div class="colophon">
                  © {new Date().getFullYear()} wahyuteguh · <a href="/">home</a>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var root = document.documentElement;
        var overlay = document.getElementById('freeze-overlay');
        var canvas = document.getElementById('freeze-canvas');
        var video = document.getElementById('freeze-video');
        var toggle = document.getElementById('theme-toggle');
        var photo = document.getElementById('polaroid');
        var spellNote = document.getElementById('spell-note');
        var freezing = false;

        // Two worlds (normal / ice) each with a day and a night mode.
        var ICE = { paper: 'ice', dark: 'ice-night', ice: 'ice', 'ice-night': 'ice-night' };
        var NORMAL = { ice: 'paper', 'ice-night': 'dark', paper: 'paper', dark: 'dark' };
        var isIce = function (m) { return m === 'ice' || m === 'ice-night'; };
        var isNight = function (m) { return m === 'dark' || m === 'ice-night'; };

        function mode() {
          return root.dataset.mode || 'paper';
        }
        function sync() {
          var m = mode();
          // toggle flips day/night within the current world
          if (isIce(m)) {
            toggle.textContent = isNight(m) ? '☀ frost' : '☾ aurora';
          } else {
            toggle.textContent = isNight(m) ? '☀ paper' : '☾ ink';
          }
          if (spellNote) spellNote.textContent = isIce(m) ? '↑thaw the frost' : '↑freeze time ❄';
          if (photo) photo.title = isIce(m) ? 'click to thaw' : 'click to freeze ❄';
        }
        function setMode(m) {
          root.dataset.mode = m;
          try {
            localStorage.setItem('wt-mode', m);
          } catch (e) {}
          sync();
        }

        // Toggle day <-> night, staying in the same world.
        toggle.addEventListener('click', function () {
          var m = mode();
          if (isIce(m)) setMode(m === 'ice' ? 'ice-night' : 'ice');
          else setMode(m === 'dark' ? 'paper' : 'dark');
        });

        // CSS-only fallback (used when the video can't play).
        function cssFreeze(target, x, y) {
          overlay.style.setProperty('--ix', x + 'px');
          overlay.style.setProperty('--iy', y + 'px');
          overlay.classList.add('spread');
          setTimeout(function () { setMode(target); }, 500);
          setTimeout(function () {
            overlay.classList.remove('spread');
            freezing = false;
          }, 1250);
        }

        // Real freeze: chroma-key the green-screen clip onto the canvas each
        // frame and stretch it over the screen, with its sound. Sped up ~4x
        // so the whole freeze lands in ~1s (4x keeps audio audible in Chrome).
        var PW = 640, PH = 360;
        var proc = document.createElement('canvas');
        proc.width = PW; proc.height = PH;
        var pctx = proc.getContext('2d', { willReadFrequently: true });
        var vctx = canvas.getContext('2d');

        function keyFrame() {
          pctx.drawImage(video, 0, 0, PW, PH);
          var img, d;
          try { img = pctx.getImageData(0, 0, PW, PH); } catch (e) { return; }
          d = img.data;
          for (var i = 0; i < d.length; i += 4) {
            var r = d[i], g = d[i + 1], b = d[i + 2];
            if (g > 90 && g > r * 1.35 && g > b * 1.35) {
              d[i + 3] = 0; // strong green -> transparent
            } else if (g > r && g > b) {
              var mx = Math.max(r, b); // suppress green spill on the ice
              if (g > mx) d[i + 1] = mx;
            }
          }
          pctx.putImageData(img, 0, 0);
          vctx.clearRect(0, 0, canvas.width, canvas.height);
          vctx.drawImage(proc, 0, 0, canvas.width, canvas.height);
        }

        function videoFreeze(target) {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
          var swapped = false, running = true, start = 0;

          function loop(ts) {
            if (!running) return;
            if (!start) start = ts;
            keyFrame();
            if (!swapped && ts - start > 380) { setMode(target); swapped = true; }
            if (video.ended || ts - start > 1500) { finish(); return; }
            requestAnimationFrame(loop);
          }
          function finish() {
            running = false;
            if (!swapped) setMode(target);
            canvas.classList.remove('on');
            setTimeout(function () {
              try { video.pause(); } catch (e) {}
              vctx.clearRect(0, 0, canvas.width, canvas.height);
              freezing = false;
            }, 300);
          }

          try { video.currentTime = 0; } catch (e) {}
          video.playbackRate = 4;
          canvas.classList.add('on');
          var p = video.play();
          if (p && p.catch) {
            p.then(function () { requestAnimationFrame(loop); })
             .catch(function () { canvas.classList.remove('on'); cssFreeze(target, window.innerWidth / 2, 120); });
          } else {
            requestAnimationFrame(loop);
          }
        }

        // Cast the freeze spell: crystallize the screen and cross worlds,
        // carrying day/night across.
        if (photo) {
          photo.addEventListener('click', function (e) {
            if (freezing) return;
            freezing = true;
            var m = mode();
            var target = isIce(m) ? NORMAL[m] : ICE[m];
            if (video && video.canPlayType && video.canPlayType('video/mp4')) {
              videoFreeze(target);
            } else {
              cssFreeze(target, e.clientX, e.clientY);
            }
          });
        }

        sync();
      })();
    </script>
  </body>
</html>

---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
---
<html lang="en" data-mode="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <script is:inline>
      try {
        var m = localStorage.getItem('wt-mode');
        document.documentElement.dataset.mode = m === 'dark' || m === 'ice-night' ? 'dark' : 'paper';
      } catch (e) {}
    </script>
  </head>
  <body class="app-body">
    <slot />
    <footer class="app-footer">
      <div class="app-footer-nav">
        <a href="/">← wahyuteguh</a>
        <span class="app-footer-sep">|</span>
        <a href="/resources/">all resources</a>
      </div>
      <div class="app-footer-tag">made with ✎ dot-paper magic</div>
      <button id="theme-toggle" class="app-footer-theme" type="button">theme: ☾ ink</button>
    </footer>
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var btn = document.getElementById('theme-toggle');
        function sync() {
          btn.textContent = 'theme: ' + (root.dataset.mode === 'dark' ? '☀ paper' : '☾ ink');
        }
        btn.addEventListener('click', function () {
          var next = root.dataset.mode === 'dark' ? 'paper' : 'dark';
          root.dataset.mode = next;
          try {
            localStorage.setItem('wt-mode', next);
          } catch (e) {}
          sync();
        });
        sync();
      })();
    </script>
  </body>
</html>
<style>
  html,
  .app-body {
    height: 100%;
  }
  .app-body {
    margin: 0;
    display: flex;
    flex-direction: column;
    background-image: none;
  }
  .app-footer {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 6px 16px;
    padding: 10px 16px;
    font-size: 13px;
    color: var(--muted);
    border-top: 1px dashed var(--faint);
    flex-shrink: 0;
  }
  .app-footer-nav {
    display: flex;
    gap: 14px;
  }
  .app-footer-nav a {
    color: inherit;
    text-decoration: none;
  }
  .app-footer-sep {
    color: var(--faint);
  }
  .app-footer-tag {
    justify-self: center;
    white-space: nowrap;
    font-family: var(--font-hand);
    font-size: 16px;
    color: var(--accent);
  }
  .app-footer-theme {
    justify-self: end;
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--muted);
    background: none;
    border: 0;
    cursor: pointer;
  }
  @media (max-width: 560px) {
    .app-footer {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .app-footer-theme {
      justify-self: center;
    }
  }
</style>
